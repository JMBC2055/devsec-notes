# ============================================================
# VARIABLES DE ENTORNO — gestor-notas
# Copia este archivo como .env para desarrollo local
# En Railway configura cada variable en el panel de Variables
# ============================================================

# --- Base de datos (Railway las llena automático) ---
# MYSQLHOST=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLPORT=3306

# --- Base de datos local (XAMPP) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devsec_notes
DB_USER=root
DB_PASS=

# --- URL de la aplicación ---
# En Railway: pega la URL que te asigna (ej: https://gestor-notas-production.up.railway.app/public)
# En local: http://localhost/gestor-notas/public
APP_URL=http://localhost/gestor-notas/public

# --- SMTP Brevo ---
# Consíguelos en: app.brevo.com → SMTP & API → SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu_clave_smtp_de_brevo
SMTP_FROM=tu@email.com
